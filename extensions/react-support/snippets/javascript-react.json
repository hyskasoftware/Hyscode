  "React Context": {
    "prefix": ["rctx", "context"],
    "body": [
      "import { createContext, useContext } from 'react';",
      "",
      "const ${1:MyContext} = createContext(${2:null});",
      "",
      "export function ${1:MyContext}Provider({ children }) {",
      "  const value = ${3:{}};",
      "",
      "  return (",
      "    <${1:MyContext}.Provider value={value}>",
      "      {children}",
      "    </${1:MyContext}.Provider>",
      "  );",
      "}",
      "",
      "export function use${1/(.*)/${1}/}() {",
      "  const context = useContext(${1:MyContext});",
      "  if (!context) {",
      "    throw new Error('use${1/(.*)/${1}/} must be used within a ${1:MyContext}Provider');",
      "  }",
      "  return context;",
      "}",
      "$0"
    ],
    "description": "React Context com Provider e hook"
  },

  "React Import": {
    "prefix": ["imr", "importreact"],
    "body": [
