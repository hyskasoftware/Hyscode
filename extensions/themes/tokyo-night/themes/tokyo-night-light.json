    "editorBracketMatch.background": "#34548a22",
    "editorBracketMatch.border": "#34548a44",
    "editor.wordHighlightBackground": "#34548a18",
    "editorWidget.background": "#cbccd1",
    "editorWidget.border": "#b8b9be",
    "input.background": "#d5d6db",
    "input.foreground": "#343b58",
    "input.border": "#b8b9be",
    "minimap.background": "#dddee3",
    "minimap.selectionHighlight": "#34548a44",
    "minimapGutter.addedBackground": "#485e30",
    "minimapGutter.modifiedBackground": "#8f5e15",
    "minimapGutter.deletedBackground": "#8c4351",
    "editorOverviewRuler.addedForeground": "#485e3088",
    "editorOverviewRuler.modifiedForeground": "#8f5e1588",
    "editorOverviewRuler.deletedForeground": "#8c435188",
    "scrollbarSlider.background": "#9699a355",
    "scrollbarSlider.hoverBackground": "#9699a388",
    "scrollbarSlider.activeBackground": "#9699a3aa",

    "sideBar.background": "#cbccd1",
    "sideBar.border": "#d5d6db",
    "activityBar.background": "#d5d6db",
    "panel.background": "#d5d6db",
    "panel.border": "#b8b9be",
    "focusBorder": "#34548a",
