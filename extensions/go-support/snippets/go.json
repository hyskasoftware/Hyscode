{
  "main() entrypoint": {
    "prefix": ["main", "gomain"],
    "body": [
      "package main",
      "",
      "import \"fmt\"",
      "",
      "func main() {",
      "\t$0",
      "}"
    ],
    "description": "Arquivo main com função main"
  },

  "Package declaration": {
    "prefix": ["pkg", "package"],
    "body": [
      "package ${1:main}"
    ],
    "description": "Declaração de package"
  },

  "import single": {
    "prefix": ["imp", "import"],
    "body": [
