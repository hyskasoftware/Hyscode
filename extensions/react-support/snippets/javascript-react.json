    "description": "Import useState e useEffect"
  },

  "React Suspense": {
    "prefix": ["susp", "suspense"],
    "body": [
      "<Suspense fallback={<${1:Loading} />}>",
      "  $0",
      "</Suspense>"
    ],
    "description": "React Suspense wrapper"
  },
  "React Error Boundary": {
    "prefix": ["errb", "errorboundary"],
    "body": [
      "import { Component } from 'react';",
      "",
      "export class ${1:ErrorBoundary} extends Component {",
      "  constructor(props) {",
      "    super(props);",
      "    this.state = { hasError: false };",
      "  }",
      "",
      "  static getDerivedStateFromError(error) {",
      "    return { hasError: true };",
      "  }",
      "",
      "  componentDidCatch(error, errorInfo) {",
      "    console.error('Error caught by boundary:', error, errorInfo);",
      "  }",
      "",
      "  render() {",
      "    if (this.state.hasError) {",
      "      return <${2:h1}>Something went wrong.</${2:h1}>;",
      "    }",
      "    return this.props.children;",
      "  }",
      "}"
    ],
    "description": "React Error Boundary class component"
  },
