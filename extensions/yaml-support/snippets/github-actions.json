{
  "GitHub Actions workflow": {
    "prefix": ["gha-workflow", "workflow"],
    "body": [
      "name: ${1:CI}",
      "",
      "on:",
      "  push:",
      "    branches: [${2:main}]",
      "  pull_request:",
      "    branches: [${2:main}]",
      "",
      "jobs:",
      "  ${3:build}:",
      "    runs-on: ${4|ubuntu-latest,windows-latest,macos-latest|}",
      "    steps:",
      "      - uses: actions/checkout@v4",
      "",
      "      - name: ${5:Setup Node.js}",
      "        uses: actions/setup-node@v4",
      "        with:",
      "          node-version: ${6:22}",
      "",
      "      - name: Install dependencies",
      "        run: ${7:npm ci}",
      "",
      "      - name: ${8:Run tests}",
      "        run: ${9:npm test}",
      "      $0"
    ],
    "description": "GitHub Actions workflow completo"
  },

  "Job": {
    "prefix": ["gha-job", "job"],
    "body": [
      "${1:job-name}:",
      "  runs-on: ${2|ubuntu-latest,windows-latest,macos-latest|}",
      "  ${3:needs: ${4:build}}",
      "  steps:",
      "    - uses: actions/checkout@v4",
      "    - name: ${5:Step name}",
      "      run: ${6:echo \"Hello\"}",
      "    $0"
    ],
    "description": "GitHub Actions job"
  },

  "Step run": {
    "prefix": ["gha-step-run", "step-run"],
    "body": [
      "- name: ${1:Step name}",
      "  run: ${2:command}",
      "  ${3:working-directory: ${4:./}}",
      "  ${5:env:}",
      "    ${6:KEY}: ${7:value}"
    ],
    "description": "Step com run"
  },

  "Step uses": {
    "prefix": ["gha-step-uses", "step-uses"],
    "body": [
      "- name: ${1:Step name}",
      "  uses: ${2:actions/checkout@v4}",
      "  with:",
      "    ${3:key}: ${4:value}"
    ],
    "description": "Step com uses (action)"
  },

  "Matrix strategy": {
    "prefix": ["gha-matrix", "matrix"],
    "body": [
      "strategy:",
      "  matrix:",
      "    ${1:node-version}: [${2:18, 20, 22}]",
      "  fail-fast: false"
    ],
    "description": "Matrix strategy"
  },

  "Docker build and push": {
    "prefix": ["gha-docker", "docker-build-push"],
    "body": [
      "- name: Set up Docker Buildx",
      "  uses: docker/setup-buildx-action@v3",
      "",
      "- name: Login to Docker Hub",
      "  uses: docker/login-action@v3",
      "  with:",
      "    username: \\${{ secrets.DOCKER_USERNAME }}",
      "    password: \\${{ secrets.DOCKER_PASSWORD }}",
      "",
      "- name: Build and push",
      "  uses: docker/build-push-action@v6",
      "  with:",
      "    context: .",
      "    push: true",
      "    tags: ${1:user/app}:latest"
    ],
    "description": "Docker build & push steps"
  },

  "Deploy to Vercel": {
    "prefix": ["gha-vercel", "vercel-deploy"],
    "body": [
      "- name: Deploy to Vercel",
      "  uses: amondnet/vercel-action@v25",
      "  with:",
      "    vercel-token: \\${{ secrets.VERCEL_TOKEN }}",
      "    vercel-org-id: \\${{ secrets.VERCEL_ORG_ID }}",
      "    vercel-project-id: \\${{ secrets.VERCEL_PROJECT_ID }}",
      "    vercel-args: ${1:--prod}"
    ],
    "description": "Deploy no Vercel via GitHub Actions"
  },

  "Cache step": {
    "prefix": ["gha-cache", "cache"],
    "body": [
      "- name: Cache ${1:node_modules}",
      "  uses: actions/cache@v4",
      "  with:",
      "    path: ${2:~/.npm}",
      "    key: \\${{ runner.os }}-${3:node}-\\${{ hashFiles('${4:**/package-lock.json}') }}",
      "    restore-keys: |",
      "      \\${{ runner.os }}-${3:node}-"
    ],
    "description": "Cache step"
  },

  "Secrets and environment": {
    "prefix": ["gha-env", "env-secrets"],
    "body": [
      "env:",
      "  ${1:DATABASE_URL}: \\${{ secrets.${2:DATABASE_URL} }}",
      "  ${3:NODE_ENV}: ${4:production}"
    ],
    "description": "Variáveis de ambiente com secrets"
  },

  "Conditional step": {
    "prefix": ["gha-if", "step-if"],
    "body": [
      "- name: ${1:Conditional step}",
      "  if: ${2:github.event_name == 'push'}",
      "  run: ${3:echo \"Running on push\"}"
    ],
    "description": "Step condicional"
  },

  "Release workflow": {
    "prefix": ["gha-release", "release"],
    "body": [
      "name: Release",
      "",
      "on:",
      "  push:",
      "    tags:",
      "      - 'v*'",
      "",
      "permissions:",
      "  contents: write",
      "",
      "jobs:",
      "  release:",
      "    runs-on: ubuntu-latest",
      "    steps:",
      "      - uses: actions/checkout@v4",
      "",
      "      - name: Create Release",
      "        uses: softprops/action-gh-release@v2",
      "        with:",
      "          generate_release_notes: true"
    ],
    "description": "Workflow para criar release em tag push"
  },

  "Schedule trigger (cron)": {
    "prefix": ["gha-cron", "schedule"],
    "body": [
      "on:",
      "  schedule:",
      "    - cron: '${1:0 0 * * *}'  # ${2:Every day at midnight UTC}"
    ],
    "description": "Trigger por schedule (cron)"
  },

  "Concurrency": {
    "prefix": ["gha-concurrency", "concurrency"],
    "body": [
      "concurrency:",
      "  group: \\${{ github.workflow }}-\\${{ github.ref }}",
      "  cancel-in-progress: true"
    ],
    "description": "Concurrency group para cancelar runs anteriores"
  }
}
