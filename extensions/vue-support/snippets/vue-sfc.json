{
  "Vue SFC (TypeScript)": {
    "prefix": ["vue", "vbase", "vsfc"],
    "body": [
      "<script setup lang=\"ts\">",
      "$0",
      "</script>",
      "",
      "<template>",
      "  <div>",
      "    ",
      "  </div>",
      "</template>",
      "",
      "<style scoped>",
      "</style>"
    ],
    "description": "Vue 3 SFC com script setup TypeScript"
  },
