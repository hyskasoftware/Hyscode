  },
  "useEffect": {
    "prefix": ["ue", "useeffect"],
    "body": [
      "useEffect(() => {",
      "  $0",
      "}, [${1}]);"
    ],
    "description": "React useEffect hook"
  },
  "useEffect with Cleanup": {
    "prefix": ["uec", "useeffectcleanup"],
    "body": [
      "useEffect(() => {",
      "  $1",
      "",
      "  return () => {",
      "    $0",
      "  };",
      "}, [${2}]);"
    ],
    "description": "React useEffect com cleanup"
