{
  "name": "hyscode",
  "version": "0.1.2-preview",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "build:prod": "pwsh -ExecutionPolicy Bypass -File ./scripts/build-windows.ps1",
    "build:prod:nsis": "pwsh -ExecutionPolicy Bypass -File ./scripts/build-windows.ps1 -NsisOnly",
    "build:prod:inno": "pwsh -ExecutionPolicy Bypass -File ./scripts/build-windows.ps1 -InnoOnly"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0"
  }
}
