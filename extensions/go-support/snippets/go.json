      "\twg.Add(1)",
      "\tgo func(${1:item} ${3:type}) {",
      "\t\tdefer wg.Done()",
      "\t\t$0",
      "\t}(${1:item})",
      "}",
      "",
      "wg.Wait()"
    ],
    "description": "Padrão com sync.WaitGroup"
  },

