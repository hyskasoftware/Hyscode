  "Table-driven test": {
    "prefix": ["testtt", "table-test"],
    "body": [
      "func Test${1:Name}(t *testing.T) {",
      "\ttests := []struct {",
      "\t\tname  string",
      "\t\tinput ${2:string}",
      "\t\twant  ${3:string}",
      "\t}{",
      "\t\t{name: \"${4:case1}\", input: ${5:\"\"}, want: ${6:\"\"}},",
      "\t\t$0",
      "\t}",
      "",
      "\tfor _, tc := range tests {",
      "\t\tt.Run(tc.name, func(t *testing.T) {",
      "\t\t\tgot := ${7:funcUnderTest}(tc.input)",
      "\t\t\tif got != tc.want {",
      "\t\t\t\tt.Errorf(\"got %v, want %v\", got, tc.want)",
      "\t\t\t}",
      "\t\t})",
      "\t}",
      "}"
    ],
    "description": "Table-driven test"
  },

