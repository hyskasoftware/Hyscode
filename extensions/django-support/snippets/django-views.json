      "        form = ${2:MyForm}(request.POST)",
      "        if form.is_valid():",
      "            form.save()",
      "            return redirect('${3:list}')",
      "    else:",
      "        form = ${2:MyForm}()",
      "    return render(request, '${4:form.html}', {'form': form})"
    ],
    "description": "View com formulário POST"
  },

