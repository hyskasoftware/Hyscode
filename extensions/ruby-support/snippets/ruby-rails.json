{
  "Rails Model": {
    "prefix": ["rmodel", "railsmodel"],
    "body": [
      "class ${1:ModelName} < ApplicationRecord",
      "  ${0:# validations, associations, scopes}",
      "end"
    ],
    "description": "Rails ActiveRecord model"
  },
  "Rails Model (full)": {
    "prefix": ["rmodelf", "railsmodelfull"],
    "body": [
      "class ${1:ModelName} < ApplicationRecord",
      "  # Validations",
      "  validates :${2:name}, presence: true",
      "",
      "  # Associations",
      "  belongs_to :${3:user}",
      "  has_many :${4:items}, dependent: :destroy",
      "",
      "  # Scopes",
      "  scope :${5:active}, -> { where(${6:active}: true) }",
      "",
      "  ${0}",
      "end"
    ],
    "description": "Rails model with validations, associations, scopes"
  },
  "Rails Controller": {
    "prefix": ["rctrl", "railscontroller"],
    "body": [
      "class ${1:Name}Controller < ApplicationController",
      "  before_action :set_${2:resource}, only: [:show, :edit, :update, :destroy]",
      "",
      "  def index",
      "    @${3:resources} = ${4:Resource}.all",
      "  end",
      "",
      "  def show",
      "  end",
      "",
      "  def new",
      "    @${2:resource} = ${4:Resource}.new",
      "  end",
      "",
      "  def create",
      "    @${2:resource} = ${4:Resource}.new(${2:resource}_params)",
      "",
      "    if @${2:resource}.save",
      "      redirect_to @${2:resource}, notice: '${5:Resource} was successfully created.'",
      "    else",
      "      render :new, status: :unprocessable_entity",
      "    end",
      "  end",
      "",
      "  def edit",
      "  end",
      "",
      "  def update",
      "    if @${2:resource}.update(${2:resource}_params)",
      "      redirect_to @${2:resource}, notice: '${5:Resource} was successfully updated.'",
      "    else",
      "      render :edit, status: :unprocessable_entity",
      "    end",
      "  end",
      "",
      "  def destroy",
      "    @${2:resource}.destroy",
      "    redirect_to ${3:resources}_url, notice: '${5:Resource} was successfully destroyed.'",
      "  end",
      "",
      "  private",
      "",
      "  def set_${2:resource}",
      "    @${2:resource} = ${4:Resource}.find(params[:id])",
      "  end",
      "",
      "  def ${2:resource}_params",
      "    params.require(:${2:resource}).permit(:${6:name}, :${7:email})",
      "  end",
      "end"
    ],
    "description": "Rails RESTful controller"
  },
  "Rails Controller (API)": {
    "prefix": ["rapi", "railsapi"],
    "body": [
      "class Api::V1::${1:Name}Controller < ApplicationController",
      "  before_action :set_${2:resource}, only: [:show, :update, :destroy]",
      "",
      "  def index",
      "    @${3:resources} = ${4:Resource}.all",
      "    render json: @${3:resources}",
      "  end",
      "",
      "  def show",
      "    render json: @${2:resource}",
      "  end",
      "",
      "  def create",
      "    @${2:resource} = ${4:Resource}.new(${2:resource}_params)",
      "",
      "    if @${2:resource}.save",
      "      render json: @${2:resource}, status: :created",
      "    else",
      "      render json: @${2:resource}.errors, status: :unprocessable_entity",
      "    end",
      "  end",
      "",
      "  def update",
      "    if @${2:resource}.update(${2:resource}_params)",
      "      render json: @${2:resource}",
      "    else",
      "      render json: @${2:resource}.errors, status: :unprocessable_entity",
      "    end",
      "  end",
      "",
      "  def destroy",
      "    @${2:resource}.destroy",
      "    head :no_content",
      "  end",
      "",
      "  private",
      "",
      "  def set_${2:resource}",
      "    @${2:resource} = ${4:Resource}.find(params[:id])",
      "  end",
      "",
      "  def ${2:resource}_params",
      "    params.require(:${2:resource}).permit(:${5:name}, :${6:email})",
      "  end",
      "end"
    ],
    "description": "Rails API controller"
  },
  "Rails Migration": {
    "prefix": ["rmigrate", "migration"],
    "body": [
      "class ${1:CreateTableName} < ActiveRecord::Migration[${2:7.1}]",
      "  def change",
      "    create_table :${3:table_name} do |t|",
      "      t.string :${4:name}",
      "      t.text :${5:description}",
      "      t.references :${6:user}, null: false, foreign_key: true",
      "",
      "      t.timestamps",
      "    end",
      "  end",
      "end"
    ],
    "description": "Rails migration"
  },
  "Rails Migration (add column)": {
    "prefix": ["migadd", "addcolumn"],
    "body": [
      "class ${1:AddColumnToTable} < ActiveRecord::Migration[${2:7.1}]",
      "  def change",
      "    add_column :${3:table_name}, :${4:column_name}, :${5:string}",
      "  end",
      "end"
    ],
    "description": "Migration to add column"
  },
  "Rails Migration (remove column)": {
    "prefix": ["migrem", "removecolumn"],
    "body": [
      "class ${1:RemoveColumnFromTable} < ActiveRecord::Migration[${2:7.1}]",
      "  def change",
      "    remove_column :${3:table_name}, :${4:column_name}",
      "  end",
      "end"
    ],
    "description": "Migration to remove column"
  },
  "Rails Migration (add index)": {
    "prefix": ["migidx", "addindex"],
    "body": [
      "class ${1:AddIndexToTable} < ActiveRecord::Migration[${2:7.1}]",
      "  def change",
      "    add_index :${3:table_name}, :${4:column_name}",
      "  end",
      "end"
    ],
    "description": "Migration to add index"
  },
