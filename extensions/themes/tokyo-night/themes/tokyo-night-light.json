  "tokenColors": [
    {
      "scope": "comment",
      "settings": { "foreground": "#9699a3", "fontStyle": "italic" }
    },
    {
      "scope": "comment.line",
      "settings": { "foreground": "#9699a3", "fontStyle": "italic" }
    },
    {
      "scope": "comment.block",
      "settings": { "foreground": "#9699a3", "fontStyle": "italic" }
    },
    {
      "scope": "keyword",
      "settings": { "foreground": "#5a4a78" }
    },
    {
      "scope": "keyword.control",
      "settings": { "foreground": "#5a4a78" }
    },
    {
      "scope": "keyword.operator",
      "settings": { "foreground": "#4c6a92" }
    },
    {
      "scope": "storage",
      "settings": { "foreground": "#5a4a78" }
    },
    {
      "scope": "storage.type",
      "settings": { "foreground": "#5a4a78" }
    },
    {
      "scope": "string",
      "settings": { "foreground": "#485e30" }
    },
    {
      "scope": "string.quoted",
      "settings": { "foreground": "#485e30" }
    },
    {
      "scope": "string.regexp",
      "settings": { "foreground": "#166775" }
    },
    {
      "scope": "constant.numeric",
      "settings": { "foreground": "#965027" }
    },
    {
      "scope": "constant.language",
      "settings": { "foreground": "#965027" }
    },
    {
      "scope": "entity.name.type",
      "settings": { "foreground": "#166775" }
    },
    {
      "scope": "entity.name.class",
      "settings": { "foreground": "#166775" }
    },
    {
      "scope": "entity.name.function",
      "settings": { "foreground": "#34548a" }
    },
    {
      "scope": "entity.name.tag",
      "settings": { "foreground": "#8c4351" }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#5a4a78" }
    },
    {
      "scope": "variable",
      "settings": { "foreground": "#343b58" }
    },
    {
      "scope": "variable.parameter",
      "settings": { "foreground": "#8f5e15" }
    },
    {
      "scope": "variable.other",
      "settings": { "foreground": "#343b58" }
    },
    {
      "scope": "support.function",
      "settings": { "foreground": "#0f4b6e" }
    },
    {
      "scope": "support.type",
      "settings": { "foreground": "#166775" }
    },
    {
      "scope": "support.class",
      "settings": { "foreground": "#166775" }
    },
    {
      "scope": "punctuation",
      "settings": { "foreground": "#4c6a92" }
    },
    {
      "scope": "meta.tag",
      "settings": { "foreground": "#8c4351" }
    },
    {
      "scope": "markup.deleted",
      "settings": { "foreground": "#8c4351" }
    },
    {
      "scope": "markup.inserted",
      "settings": { "foreground": "#485e30" }
    }
  ]
