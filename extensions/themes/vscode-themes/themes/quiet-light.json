{
  "id": "vscode-quiet-light",
  "label": "Quiet Light (VS Code)",
  "type": "light",
  "colors": {
    "editor.background": "#f5f5f5",
    "editor.foreground": "#333333",
    "editorLineNumber.foreground": "#aaaaaa",
    "editorLineNumber.activeForeground": "#777777",
    "editor.selectionBackground": "#c9d0d9",
    "editor.lineHighlightBackground": "#e8e8e8",
    "editorCursor.foreground": "#54494b",
    "editorIndentGuide.background": "#d8d8d8",
    "editorIndentGuide.activeBackground": "#aaaaaa",
    "editorBracketMatch.background": "#88888820",
    "editorBracketMatch.border": "#b9b9b9",
    "editor.wordHighlightBackground": "#88888820",
    "editorWidget.background": "#e8e8e8",
    "editorWidget.border": "#c8c8c8",
    "input.background": "#ffffff",
    "input.foreground": "#333333",
    "input.border": "#c8c8c8",
    "minimap.background": "#f5f5f5",
    "minimap.selectionHighlight": "#c9d0d980",
    "minimapGutter.addedBackground": "#587c0c",
    "minimapGutter.modifiedBackground": "#0c7d9d",
    "minimapGutter.deletedBackground": "#94151b",
    "editorOverviewRuler.addedForeground": "#587c0c88",
    "editorOverviewRuler.modifiedForeground": "#0c7d9d88",
    "editorOverviewRuler.deletedForeground": "#94151b88",
    "scrollbarSlider.background": "#aaaaaa55",
    "scrollbarSlider.hoverBackground": "#aaaaaa88",
    "scrollbarSlider.activeBackground": "#aaaaaaaa",

    "sideBar.background": "#ebebeb",
    "sideBar.border": "#dddddd",
    "activityBar.background": "#5f5a60",
    "panel.background": "#f5f5f5",
    "panel.border": "#d8d8d8",
    "focusBorder": "#007acc",
    "button.background": "#007acc",
    "button.foreground": "#ffffff",
    "tab.inactiveForeground": "#333333b3",
    "tab.activeForeground": "#333333",
    "errorForeground": "#a1260d",

    "terminal.ansiBlack": "#333333",
    "terminal.ansiRed": "#cd3131",
    "terminal.ansiGreen": "#00bc00",
    "terminal.ansiYellow": "#949800",
    "terminal.ansiBlue": "#0451a5",
    "terminal.ansiMagenta": "#bc05bc",
    "terminal.ansiCyan": "#0598bc",
    "terminal.ansiWhite": "#555555",
    "terminal.ansiBrightBlack": "#666666",
    "terminal.ansiBrightRed": "#cd3131",
    "terminal.ansiBrightGreen": "#14ce14",
    "terminal.ansiBrightYellow": "#b5ba00",
    "terminal.ansiBrightBlue": "#0451a5",
    "terminal.ansiBrightMagenta": "#bc05bc",
    "terminal.ansiBrightCyan": "#0598bc",
    "terminal.ansiBrightWhite": "#a5a5a5"
  },
  "tokenColors": [
    {
      "scope": ["comment", "comment.line", "comment.block"],
      "settings": { "foreground": "#aaaaaa", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "keyword.control"],
      "settings": { "foreground": "#4b69c6" }
    },
    {
      "scope": ["storage"],
      "settings": { "foreground": "#4b69c6" }
    },
    {
      "scope": ["storage.type"],
      "settings": { "foreground": "#4b69c6" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#777777" }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#448c27" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#4a8f0f" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#ab6526" }
    },
    {
      "scope": ["constant.language"],
      "settings": { "foreground": "#4b69c6" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class"],
      "settings": { "foreground": "#7a3e9d" }
    },
    {
      "scope": ["entity.name.function"],
      "settings": { "foreground": "#aa3731" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#4b69c6" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#91006b" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#7a3e9d" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#5c5c5c" }
    },
    {
      "scope": ["support.function"],
      "settings": { "foreground": "#aa3731" }
    },
    {
      "scope": ["support.type", "support.class"],
      "settings": { "foreground": "#7a3e9d" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#777777" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#4b69c6", "fontStyle": "bold" }
    }
  ]
}
