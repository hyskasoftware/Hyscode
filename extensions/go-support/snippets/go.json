  "Slice contains (generic)": {
    "prefix": ["contains", "slicecontains"],
    "body": [
      "func Contains[T comparable](s []T, v T) bool {",
      "\tfor _, item := range s {",
      "\t\tif item == v {",
      "\t\t\treturn true",
      "\t\t}",
      "\t}",
      "\treturn false",
      "}"
    ],
    "description": "Função genérica Contains para slices"
  },

  "Map (generic transform)": {
    "prefix": ["mapfunc", "slicemap"],
    "body": [
      "func Map[T, U any](s []T, f func(T) U) []U {",
      "\tresult := make([]U, len(s))",
      "\tfor i, v := range s {",
      "\t\tresult[i] = f(v)",
      "\t}",
      "\treturn result",
      "}"
    ],
    "description": "Função genérica Map para slices"
  },

  "Filter (generic)": {
    "prefix": ["filterfunc", "slicefilter"],
    "body": [
      "func Filter[T any](s []T, f func(T) bool) []T {",
      "\tresult := make([]T, 0)",
      "\tfor _, v := range s {",
      "\t\tif f(v) {",
      "\t\t\tresult = append(result, v)",
      "\t\t}",
      "\t}",
      "\treturn result",
      "}"
    ],
    "description": "Função genérica Filter para slices"
  },

