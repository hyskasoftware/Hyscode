  "Rails Policy (Pundit)": {
    "prefix": ["policy", "rpolicy"],
    "body": [
      "class ${1:Model}Policy < ApplicationPolicy",
      "  class Scope < Scope",
      "    def resolve",
      "      scope.all",
      "    end",
      "  end",
      "",
      "  def index?",
      "    true",
      "  end",
      "",
      "  def show?",
      "    true",
      "  end",
      "",
      "  def create?",
      "    user.admin?",
      "  end",
      "",
      "  def update?",
      "    user.admin? || record.user == user",
      "  end",
      "",
      "  def destroy?",
      "    user.admin?",
      "  end",
      "end"
    ],
    "description": "Pundit policy"
  },
  "Rails Serializer": {
    "prefix": ["serializer", "rserializer"],
    "body": [
