      "  const [${3:state}, set${3/(.*)/${1:/capitalize}/}] = useState(${4:null});",
      "",
      "  useEffect(() => {",
      "    $0",
      "  }, []);",
      "",
      "  return { ${3:state} };",
      "}"
    ],
    "description": "Custom React hook"
  },

  "JSX Fragment": {
