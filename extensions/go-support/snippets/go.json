      "\t\tfor _, v := range ${2:s} {",
      "\t\t\tif !yield(v) {",
      "\t\t\t\treturn",
      "\t\t\t}",
      "\t\t}",
      "\t}",
      "}"
    ],
    "description": "iter.Seq para range over function (Go 1.23+)"
  },

